# Configuration for the Quantum Circuit Execution Engine (REFERENCE §10).
#
# Every value below is also the in-code default (api/app/config.py and
# worker/app/config.py), so the stack runs correctly with NO .env at all.
# Copy this file to `.env` only when you want to override a default:
#
#     cp .env.example .env
#
# docker-compose.yml loads `.env` with required:false, so a missing file is fine.

# Redis connection string — broker + task state store.
# Host `redis` is the Compose service name on the default network.
REDIS_URL=redis://redis:6379/0

# Name of the RQ queue shared by the api (producer) and worker (consumer).
RQ_QUEUE_NAME=default

# Simulator shot count (worker).
NUM_SHOTS=1024

# Hard per-job ceiling, in seconds (api enqueue + worker execution).
JOB_TIMEOUT=180

# TTL, in seconds, applied to task:{id} state and RQ result metadata.
RESULT_TTL=86400

# RQ Retry attempts for transient faults (api enqueue).
MAX_RETRIES=2

# Logging verbosity for all services (DEBUG, INFO, WARNING, ERROR).
LOG_LEVEL=INFO
